# ============================================================================
# Configuración del Agente de Revisión de Código — NTech-TRNM
# Copia este archivo a `.env` y rellena los valores. NUNCA subas `.env` a git.
# ============================================================================

# ---- Backend del LLM ----
# "cloudrun"  = vLLM propio en GCP Cloud Run (self-hosted, requiere GPU L4)
# "ollama"    = modelo local vía Ollama (corre en tu hardware, barato/offline)
# "anthropic" = API de Anthropic (Claude), pay-per-token, sin infra que mantener
NTECH_LLM_BACKEND=cloudrun

# ---- Cloud Run (vLLM / Qwen3-Coder-30B-A3B) ----
# URL del servicio Cloud Run (termina SIN /v1; el cliente lo añade)
NTECH_CLOUDRUN_URL=https://ntech-vllm-xxxxxxxxxx-uc.a.run.app
NTECH_CLOUDRUN_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
# Ruta al JSON de la service account con rol roles/run.invoker (para mintear ID tokens).
# Si se deja vacío, se usan las Application Default Credentials (gcloud auth application-default login).
GOOGLE_APPLICATION_CREDENTIALS=

# ---- Ollama (modelo local) ----
NTECH_OLLAMA_URL=http://localhost:11434/v1
NTECH_OLLAMA_MODEL=qwen2.5-coder:7b

# ---- Anthropic (Claude API) ----
# Genera tu key en https://console.anthropic.com (cuenta y facturación separadas
# de una suscripción Claude Pro/Max). Requiere crédito prepagado (mínimo $5).
NTECH_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# claude-opus-4-8 (máxima calidad) | claude-sonnet-5 (más barato, casi la misma
# calidad en código/agentic) | claude-haiku-4-5 (rápido/económico)
NTECH_ANTHROPIC_MODEL=claude-opus-4-8

# ---- Embeddings (locales, corren en tu máquina) ----
NTECH_EMBEDDING_MODEL=BAAI/bge-m3
NTECH_EMBEDDING_DEVICE=cpu

# ---- GitHub ----
# PAT (fine-grained o classic) con permiso de LECTURA de los repos de la org.
NTECH_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
NTECH_GITHUB_ORG=NTech-TRNM
# Endpoint del GitHub MCP remoto (hosted). Deja el default salvo que uses uno propio.
NTECH_GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/

# ---- Rutas de datos (relativas a la raíz del repo) ----
NTECH_REPOS_DIR=data/repos
NTECH_INDEX_DIR=data/index
NTECH_REPORTS_DIR=data/reports
NTECH_GUIDELINES_DIR=guidelines
NTECH_SKILLS_DIR=skills

# ---- Parámetros de RAG ----
NTECH_CHROMA_COLLECTION=ntech_code
NTECH_CHUNK_SIZE=1200
NTECH_CHUNK_OVERLAP=150
NTECH_RETRIEVAL_K=8
NTECH_RETRIEVAL_FETCH_K=24
NTECH_RERANK_ENABLED=true
NTECH_RERANK_THRESHOLD=0.3

# ---- Análisis estático ----
NTECH_STATIC_ANALYSIS_ENABLED=true
